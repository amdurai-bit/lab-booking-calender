# ─────────────────────────────────────────────────────────────────────────────
# LASER LAB BOOKING — Environment Variables
# Copy this file to .env.local and fill in the value below.
# On Vercel: Settings → Environment Variables → add SESSION_SECRET.
# ─────────────────────────────────────────────────────────────────────────────

# A random 32+ character string used to sign session cookies.
# Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_A_RANDOM_32_CHAR_SECRET

# ── Data storage ──────────────────────────────────────────────────────────────
# Users and bookings are stored as plain JSON files in data/ (no database needed):
#   data/allowed-users.json  →  add email strings to grant access
#   data/bookings.json       →  written automatically on each booking
#
# To add a user: open data/allowed-users.json and add their email to the array.
# To migrate to OneDrive/Excel later: swap lib/storage.ts for lib/graph.ts.
