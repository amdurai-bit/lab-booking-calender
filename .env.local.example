# ─────────────────────────────────────────────────────────────────────────────
# LASER LAB BOOKING — Environment Variables
# Copy this file to .env.local and fill in all values before running.
# On Vercel: paste these into Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Session ──────────────────────────────────────────────────────────────────
# A random 32+ character secret used to sign session JWTs.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=REPLACE_WITH_A_RANDOM_32_CHAR_SECRET

# ── Azure App Registration ────────────────────────────────────────────────────
# 1. Go to https://portal.azure.com → Azure Active Directory → App registrations → New registration
# 2. Name it (e.g. "Laser Lab Booking"), leave defaults, click Register.
# 3. Copy the Directory (tenant) ID and Application (client) ID below.
# 4. Go to Certificates & secrets → New client secret → copy the VALUE (not the ID).
# 5. Go to API permissions → Add a permission → Microsoft Graph → Application permissions
#    → Add: Files.ReadWrite.All → Grant admin consent.
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-value-here

# ── OneDrive / Excel File ─────────────────────────────────────────────────────
# Find your Drive ID and File Item ID via Graph Explorer (https://developer.microsoft.com/en-us/graph/graph-explorer):
#
# Step 1 – Find the Drive ID:
#   GET https://graph.microsoft.com/v1.0/users/{adminEmail}/drive
#   Copy the "id" field → ONEDRIVE_DRIVE_ID
#
# Step 2 – Find the File Item ID:
#   GET https://graph.microsoft.com/v1.0/drives/{driveId}/root:/{path/to/LaserLabBookings.xlsx}
#   Copy the "id" field → ONEDRIVE_FILE_ID
#
# The Excel file MUST have two tables named exactly:
#   • AllowedUsers  → one column: email
#   • Bookings      → columns: id, user_email, project_name, weld_combinations,
#                              material, weld_count, risk_assessment,
#                              system_issues, additional_info, booking_date, slot_time
ONEDRIVE_DRIVE_ID=your-drive-id-here
ONEDRIVE_FILE_ID=your-excel-file-item-id-here
